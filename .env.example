# ScreenGrabber Local Development Environment Variables
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control — it is in .gitignore.

# AI Provider API Keys (used for BYOK testing in DEBUG builds)
MINIMAX_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Internal subscription AI backend (leave empty to use BYOK fallback)
SG_AI_ENDPOINT=

# Internal encrypted key bytes (base64, generated via SecureKeyStore.obfuscate)
# See API_MAINTENANCE.md for rotation instructions
SG_INTERNAL_KEY=
